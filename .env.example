# Copy to `.env` and fill with values from Supabase → Project Settings → API.
# Restart Expo (`npx expo start --clear`) after changing env.
#
# The anon key is designed for client apps (protected by Row Level Security).
#
# Wardrobe + outfits + wardrobe photos + Discover: run SQL in `supabase/migrations/`
# (wardrobe_items, outfits, wardrobe_images_storage, published_outfits,
# published_outfits_author_delete, published_outfit_likes, wardrobe_image_refs,
# profiles, user_follows, following_feed_rpc (20260329190500), published_outfit_comments,
# user_activity, 20260329220000_user_activity_read_at) in the Supabase SQL Editor (and enable Email auth under Authentication → Providers).
#
# Wardrobe derivatives: deploy Edge Function `process-wardrobe-image`
# (`supabase/functions/process-wardrobe-image`) — see summary in repo deliverable notes.
#
# Outfit suggestion (Outfits → “Suggest an outfit”) is fully on-device: no API keys or backend required.
# Optional feedback sync: run `supabase/migrations/20260329240000_outfit_suggestion_feedback.sql` so
# signed-in users log reactions (like / not my style / etc.) to `outfit_suggestion_feedback`.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Native avatar export bridge (optional): absolute path to this git repo so the app can
# write/read generated/avatar_requests and generated/avatar_renders alongside the engine.
# Example (Windows): EXPO_PUBLIC_CLOSY_REPO_ROOT=E:\\apps\\Closy
# Example (macOS/Linux): EXPO_PUBLIC_CLOSY_REPO_ROOT=/Users/you/projects/Closy
#
# Mock PNG for UI tests (no engine): EXPO_PUBLIC_AVATAR_EXPORT_MOCK=1
# Optional placeholder URL: EXPO_PUBLIC_AVATAR_EXPORT_MOCK_URI=https://…
# EXPO_PUBLIC_CLOSY_REPO_ROOT=
# EXPO_PUBLIC_AVATAR_EXPORT_MOCK=
#
# Dev Android/iOS preview: serve repo root over HTTP (`npx serve .`), then either set:
# EXPO_PUBLIC_AVATAR_RENDER_BASE_URL=http://YOUR_LAN_IP:3000
# or rely on inferred host from Metro + EXPO_PUBLIC_AVATAR_RENDER_SERVE_PORT (default 3000).
# EXPO_PUBLIC_AVATAR_RENDER_BASE_URL=
# EXPO_PUBLIC_AVATAR_RENDER_SERVE_PORT=3000
